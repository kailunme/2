---
import SynthPanel from './SynthPanel';

interface Props { current: 'en' | 'zh' | 'ja'; }
const { current } = Astro.props;
---

<style>
  .ctrl-panel {
    background: var(--ua-panel-bg);
    border: 1px solid var(--ua-panel-border);
    border-radius: var(--ua-panel-radius);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.75) inset,
      0 -1px 0 0 rgba(140,170,210,0.2) inset,
      0 6px 32px rgba(100,130,180,0.15),
      0 2px 8px rgba(100,130,180,0.1);
    padding: 12px 14px;
    margin-top: 16px;
  }

  @media (max-width: 700px) {
    .ctrl-panel { margin-top: 0; }
  }
</style>

<div class="ctrl-panel">
  <SynthPanel current={current} client:load />
</div>
