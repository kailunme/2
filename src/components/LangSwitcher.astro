---
interface Props { current: 'en' | 'zh' | 'ja'; }
const { current } = Astro.props;

const langs = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'zh', label: 'ZH', href: '/zh/' },
  { code: 'ja', label: 'JA', href: '/ja/' },
] as const;
---

<style>
  .lang-switcher {
    display: flex;
    gap: 6px;
    margin-top: 12px;
  }
  .lang-btn {
    flex: 1;
    padding: 7px 0;
    border: 1px solid var(--ua-panel-border);
    border-radius: 12px;
    font-family: 'Forced Square', sans-serif;
    font-size: 12px;
    letter-spacing: 2px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    color: #8b939c;
    background: linear-gradient(180deg, #ffffff, #f0f4fa);
    box-shadow: 0 1px 3px rgba(180,200,230,0.4), inset 0 -1px 3px rgba(180,200,230,0.3);
    transition: color 0.15s, background 0.15s, box-shadow 0.15s, border-color 0.15s;
    user-select: none;
  }
  .lang-btn:hover {
    color: #4a8fd4;
    background: linear-gradient(180deg, #f0f6ff, #e8f0fa);
    box-shadow: 0 2px 6px rgba(100,160,220,0.2), inset 0 -1px 3px rgba(180,200,230,0.3);
    border-color: rgba(100,160,220,0.5);
  }
  .lang-btn.active {
    color: #4a8fd4;
    background: linear-gradient(180deg, #dce8f5, #e8f0fa);
    box-shadow: inset 0 2px 5px rgba(100,150,210,0.35), inset 0 1px 2px rgba(80,130,190,0.2);
    border-color: rgba(100,160,220,0.6);
  }
</style>

<div class="lang-switcher">
  {langs.map(l => (
    <a href={l.href} class={`lang-btn${l.code === current ? ' active' : ''}`}>
      {l.label}
    </a>
  ))}
</div>
